{
  "cniVersion": "1.0.0",
  "name": "ecs-bridge",
  "plugins": [
    {
      "type": "bridge",
      "bridge": "ecs0",
      "isGateway": true,
      "ipMasq": true,
      "ipam": {
        "type": "host-local",
        "ranges": [
          [{ "subnet": "172.31.0.0/16" }]
        ],
        "routes": [{ "dst": "0.0.0.0/0" }]
      }
    },
    { "type": "portmap", "capabilities": { "portMappings": true } },
    { "type": "firewall" }
  ]
}
